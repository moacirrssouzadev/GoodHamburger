@using GoodHamburger.Web.Shared.Models

<div class="menu-item-row">
    <div class="item-info">
        <h6 class="item-name">@Item.Name</h6>
        <span class="item-type">@TranslateType(Item.Type)</span>
    </div>
    <div class="item-price">
        <strong>@Item.Price.ToString("C")</strong>
    </div>
</div>

<style>
    .menu-item-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem;
        border: 1px solid #e9ecef;
        border-radius: 8px;
        background: white;
        transition: all 0.3s ease;
        margin-bottom: 0.5rem;
    }

    .menu-item-row:hover {
        border-color: #ff6b35;
        background: #fff9f7;
        box-shadow: 0 2px 8px rgba(255, 107, 53, 0.1);
    }

    .item-info {
        flex: 1;
    }

    .item-name {
        margin: 0;
        color: #333;
        font-weight: 600;
    }

    .item-type {
        color: #999;
        font-size: 0.85rem;
        background: #f0f0f0;
        padding: 0.25rem 0.5rem;
        border-radius: 4px;
        display: inline-block;
        margin-top: 0.25rem;
    }

    .item-price {
        color: #ff6b35;
        font-size: 1.1rem;
    }
</style>

@code {
    [Parameter]
    public MenuItem Item { get; set; } = new();

    private string TranslateType(ItemType type) => type switch
    {
        ItemType.Sandwich => "Sanduíche",
        ItemType.Fries => "Acompanhamento",
        ItemType.Drink => "Refrigerante",
        _ => "Item"
    };
}
