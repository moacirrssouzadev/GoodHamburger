@page "/create-order"
@page "/edit-order/{OrderId:guid}"
@using GoodHamburger.Web.Shared.Models
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="create-order-page">
    <div class="page-header">
        <div class="header-content">
            <h1>@(OrderId == Guid.Empty ? "Novo Pedido" : $"Editar Pedido")</h1>
            <p class="subtitle">Selecione os itens desejados e finalize seu pedido</p>
        </div>
    </div>

    @if (menuItems == null)
    {
        <div class="loading-state">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Carregando...</span>
            </div>
            <p>Carregando cardápio...</p>
        </div>
    }
    else
    {
        <div class="menu-sections">
            <CategorySection
                CategoryName="Sanduíches"
                Items="@menuItems.Where(i => i.Type == ItemType.Sandwich).ToList()"
                SelectedIds="@selectedIds"
                OnItemSelected="@OnItemSelected"
            />

            <CategorySection
                CategoryName="Acompanhamentos"
                Items="@menuItems.Where(i => i.Type == ItemType.Fries).ToList()"
                SelectedIds="@selectedIds"
                OnItemSelected="@OnItemSelected"
            />

            <CategorySection
                CategoryName="Refrigerantes"
                Items="@menuItems.Where(i => i.Type == ItemType.Drink).ToList()"
                SelectedIds="@selectedIds"
                OnItemSelected="@OnItemSelected"
            />
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <strong>Erro!</strong> @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
            </div>
        }

        <div class="action-buttons">
            <button class="btn btn-success btn-lg" @onclick="SaveOrder" disabled="@(!selectedIds.Any())">
                <i class="bi bi-check-circle"></i> Salvar Pedido
            </button>
            <button class="btn btn-secondary btn-lg" @onclick="Cancel">
                <i class="bi bi-x-circle"></i> Cancelar
            </button>
        </div>
    }
</div>

<style>
    .create-order-page {
        padding: 2rem 0;
    }

    .page-header {
        margin-bottom: 2rem;
        padding: 2rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 12px;
        color: white;
    }

    .header-content h1 {
        margin: 0;
        font-size: 2rem;
        font-weight: 700;
    }

    .subtitle {
        margin: 0.5rem 0 0 0;
        opacity: 0.95;
        font-size: 0.95rem;
    }

    .loading-state {
        text-align: center;
        padding: 3rem 2rem;
        background: white;
        border-radius: 12px;
        border: 1px solid #eee;
    }

    .menu-sections {
        margin-bottom: 2rem;
    }

    .action-buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
        padding: 2rem;
        background: white;
        border-radius: 12px;
        border: 1px solid #eee;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .action-buttons .btn {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 2rem;
        font-weight: 600;
    }

    .action-buttons .btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    @@media (max-width: 768px) {
        .action-buttons {
            flex-direction: column;
        }

        .action-buttons .btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>

@code {
    [Parameter] public Guid OrderId { get; set; }
    private List<MenuItem>? menuItems;
    private HashSet<int> selectedIds = new();
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {        menuItems = await Http.GetFromJsonAsync<List<MenuItem>>("api/menu");

        if (OrderId != Guid.Empty)
        {
            var order = await Http.GetFromJsonAsync<Order>($"api/orders/{OrderId}");
            if (order != null)
            {
                selectedIds = new HashSet<int>(order.Items.Select(i => i.Id));
            }
        }
    }

    private void OnItemSelected((int id, bool selected) item)
    {
        if (item.selected)
        {
            selectedIds.Add(item.id);
        }
        else
        {
            selectedIds.Remove(item.id);
        }
    }

    private async Task SaveOrder()
    {
        errorMessage = null;
        var dto = new OrderCreateDto { ItemIds = selectedIds.ToList() };
        HttpResponseMessage response;

        if (OrderId == Guid.Empty)
        {
            response = await Http.PostAsJsonAsync("api/orders", dto);
        }
        else
        {
            response = await Http.PutAsJsonAsync($"api/orders/{OrderId}", dto);
        }

        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/");
        }
        else
        {
            errorMessage = await response.Content.ReadAsStringAsync();
        }
    }

    private void Cancel()
    {        Navigation.NavigateTo("/");
    }
}
