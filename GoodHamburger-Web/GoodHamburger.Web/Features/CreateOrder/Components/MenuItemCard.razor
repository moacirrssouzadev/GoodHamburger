@using GoodHamburger.Web.Shared.Models

<div class="menu-item-card">
    <div class="item-header">
        <h6 class="item-name">@Item.Name</h6>
        <span class="item-price">@Item.Price.ToString("C")</span>
    </div>
    
    <div class="item-selector">
        <input 
            type="checkbox" 
            class="form-check-input" 
            checked="@IsSelected"
            @onchange="@((ChangeEventArgs e) => OnSelectionChanged.InvokeAsync((bool)e.Value!))"
        />
        <label class="form-check-label">Selecionar</label>
    </div>
</div>

<style>
    .menu-item-card {
        border: 2px solid #e9ecef;
        border-radius: 8px;
        padding: 12px;
        margin-bottom: 10px;
        transition: all 0.3s ease;
        background: #fff;
    }

    .menu-item-card:hover {
        border-color: #ff6b35;
        box-shadow: 0 2px 8px rgba(255, 107, 53, 0.15);
        transform: translateY(-2px);
    }

    .item-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 8px;
    }

    .item-name {
        margin: 0;
        font-weight: 600;
        color: #333;
    }

    .item-price {
        font-weight: 700;
        color: #ff6b35;
        font-size: 0.95rem;
    }

    .item-selector {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .form-check-input {
        cursor: pointer;
        width: 18px;
        height: 18px;
    }

    .form-check-label {
        margin: 0;
        cursor: pointer;
        user-select: none;
    }
</style>

@code {
    [Parameter]
    public MenuItem Item { get; set; } = new();

    [Parameter]
    public bool IsSelected { get; set; }

    [Parameter]
    public EventCallback<bool> OnSelectionChanged { get; set; }
}
